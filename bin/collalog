#!/usr/bin/env bash
# collalog — Collaborative logging for AI-assisted teams
# Central unified log + commands/skills/prompts for multi-person + agent collaboration

set -euo pipefail

VERSION="0.6.0"
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT_DIR="$(dirname "$SCRIPT_DIR")"
TEMPLATES_DIR="$ROOT_DIR/templates"
LIB_DIR="$ROOT_DIR/lib"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
BLUE='\033[0;34m'
YELLOW='\033[1;33m'
NC='\033[0m'

log()   { echo -e "${GREEN}[collalog]${NC} $1"; }
warn()  { echo -e "${YELLOW}[collalog]${NC} $1"; }
error() { echo -e "${RED}[collalog]${NC} $1" >&2; }
info()  { echo -e "${BLUE}[collalog]${NC} $1"; }

# ─── AGENT CONFIGURATIONS ─────────────────────────────────────────────────

declare -A AGENT_COMMANDS_DIR=(
  [claude]=".claude/commands"
  [codex]=".codex/prompts"
  [cursor]=".cursor/commands"
  [gemini]=".gemini/commands"
  [windsurf]=".windsurf/workflows"
  [copilot]=".github/agents"
  [kilo]=".kilocode/workflows"
  [roo]=".roo/commands"
  [opencode]=".opencode/command"
  [kiro]=".kiro/prompts"
  [amp]=".agents/commands"
  [openclaw]=".collalog/commands"
)

agent_command_filename() {
  local agent="$1" name="$2"
  case "$agent" in
    copilot) echo "${name}.agent.md" ;;
    gemini)  echo "${name}.toml" ;;
    *)       echo "${name}.md" ;;
  esac
}

get_commands_dir() {
  local agent="$1"
  echo "${AGENT_COMMANDS_DIR[$agent]:-".collalog/commands"}"
}

# ─── USAGE ─────────────────────────────────────────────────────────────────

usage() {
  cat <<EOF
collalog v${VERSION} — Collaborative logging for AI-assisted teams

Usage:
  collalog init [path]          Initialize a new project
  collalog setup                Interactive project configuration
  collalog update               Update commands/skills/prompts from templates
  collalog sync                 Show diff between project and templates
  collalog version              Show version

Options:
  --agent <type>    AI tool: claude (default), codex, cursor, gemini,
                    windsurf, copilot, kilo, roo, opencode, kiro, amp, openclaw
  --lang <lang>     Language for project files: en (default), de
  --help            Show this help

After init, use these agent commands:
  /collalog:setup               Project setup wizard (one-time)
  /collalog:log <description>   Add a log entry manually
  /collalog:save [description]  Save current work (log + commit)
  /collalog:status              Project overview

Examples:
  collalog init .
  collalog --agent codex init ./project
  collalog setup
EOF
}

# ─── INIT ──────────────────────────────────────────────────────────────────

install_file() {
  local source_file="$1" target_dir="$2" agent="$3"
  local base_name=$(basename "$source_file" .md)
  local target_name=$(agent_command_filename "$agent" "$base_name")
  local target_file="$target_dir/$target_name"

  if [[ ! -f "$target_file" ]]; then
    cp "$source_file" "$target_file"
    info "  + $(basename "$target_dir")/$target_name"
  else
    warn "  ~ $(basename "$target_dir")/$target_name (exists, skipped)"
  fi
}

cmd_init() {
  local target="${1:-.}"
  local agent="${AGENT:-claude}"
  local lang="${LANG_OPT:-en}"

  if [[ -z "${AGENT_COMMANDS_DIR[$agent]+x}" ]]; then
    error "Unknown agent: $agent"
    error "Supported: ${!AGENT_COMMANDS_DIR[*]}"
    exit 1
  fi

  if [[ ! -d "$target" ]]; then
    mkdir -p "$target"
    log "Created directory: $target"
  fi
  target="$(cd "$target" && pwd)"

  local commands_dir=$(get_commands_dir "$agent")

  log "Initializing collalog in: $target"
  log "Agent: $agent | Commands: $commands_dir | Language: $lang"
  echo ""

  # Create collalog/ — the single user-facing directory
  mkdir -p "$target/collalog"
  info "  + collalog/"

  # Create .collalog/ — fixed elements (skills, prompts, templates, config)
  mkdir -p "$target/.collalog"/{skills,prompts,templates/commands,templates/skills,templates/prompts}
  info "  + .collalog/"

  # Create agent-specific commands directory
  mkdir -p "$target/$commands_dir"
  info "  + $commands_dir/"

  # Install COMMANDS → agent commands directory (user-invokable)
  log "Installing commands to $commands_dir..."
  for cmd in "$TEMPLATES_DIR/commands"/*.md; do
    [[ -f "$cmd" ]] || continue
    install_file "$cmd" "$target/$commands_dir" "$agent"
  done

  # Install SKILLS → .collalog/skills/ (agent rules, always active)
  log "Installing skills to .collalog/skills..."
  for skill in "$TEMPLATES_DIR/skills"/*.md; do
    [[ -f "$skill" ]] || continue
    local name=$(basename "$skill")
    if [[ ! -f "$target/.collalog/skills/$name" ]]; then
      cp "$skill" "$target/.collalog/skills/$name"
      info "  + .collalog/skills/$name"
    else
      warn "  ~ .collalog/skills/$name (exists, skipped)"
    fi
  done

  # Install PROMPTS → .collalog/prompts/ (scheduled behaviors)
  log "Installing prompts to .collalog/prompts..."
  for prompt in "$TEMPLATES_DIR/prompts"/*.md; do
    [[ -f "$prompt" ]] || continue
    local name=$(basename "$prompt")
    if [[ ! -f "$target/.collalog/prompts/$name" ]]; then
      cp "$prompt" "$target/.collalog/prompts/$name"
      info "  + .collalog/prompts/$name"
    else
      warn "  ~ .collalog/prompts/$name (exists, skipped)"
    fi
  done

  # Store original templates for update/sync
  log "Storing templates..."
  cp "$TEMPLATES_DIR/commands"/*.md "$target/.collalog/templates/commands/" 2>/dev/null || true
  cp "$TEMPLATES_DIR/skills"/*.md "$target/.collalog/templates/skills/" 2>/dev/null || true
  cp "$TEMPLATES_DIR/prompts"/*.md "$target/.collalog/templates/prompts/" 2>/dev/null || true
  info "  + .collalog/templates/ (originals for sync)"

  # Create collalog data files from templates (skip me.md — it's local-only, created during setup)
  log "Creating collalog files..."
  for tmpl in "$TEMPLATES_DIR/collalog"/*.md; do
    [[ -f "$tmpl" ]] || continue
    local name=$(basename "$tmpl")
    [[ "$name" == "me.md" ]] && continue
    if [[ ! -f "$target/collalog/$name" ]]; then
      cp "$tmpl" "$target/collalog/$name"
      info "  + collalog/$name"
    else
      warn "  ~ collalog/$name (exists, skipped)"
    fi
  done

  # Create .gitignore with local-only files
  local gitignore="$target/.gitignore"
  local me_entry="collalog/me.md"
  if [[ ! -f "$gitignore" ]]; then
    cat > "$gitignore" <<GITIGNORE
# collalog — local-only files (not shared via git)
collalog/me.md
GITIGNORE
    info "  + .gitignore (with collalog/me.md)"
  elif ! grep -qF "$me_entry" "$gitignore"; then
    echo "" >> "$gitignore"
    echo "# collalog — local-only files" >> "$gitignore"
    echo "collalog/me.md" >> "$gitignore"
    info "  ~ .gitignore (added collalog/me.md)"
  fi

  # Copy CLAUDE.md template
  if [[ ! -f "$target/CLAUDE.md" ]]; then
    cp "$TEMPLATES_DIR/CLAUDE.md.template" "$target/CLAUDE.md"
    info "  + CLAUDE.md (template — run '/collalog:setup' to configure)"
  else
    warn "  ~ CLAUDE.md (exists, skipped)"
  fi

  # Write config
  cat > "$target/.collalog/config.yaml" <<YAML
# collalog configuration
version: "${VERSION}"
agent: "${agent}"
commands_dir: "${commands_dir}"
language: "${lang}"
initialized: "$(date -Iseconds)"
template_source: "${ROOT_DIR}"

# Project settings (populated by /collalog:setup)
project:
  name: ""
  description: ""
  team: []
YAML

  echo ""
  log "Done! Project initialized."
  echo ""
  log "What was installed:"
  info "  collalog/               Log, tasks, project (user-facing data)"
  info "  $commands_dir/     Commands (user invokes these)"
  info "  .collalog/skills/       Skills (agent rules, always active)"
  info "  .collalog/prompts/      Prompts (scheduled behaviors)"
  info "  CLAUDE.md               Main agent prompt"
  echo ""
  log "Next steps:"
  log "  1. Run /collalog:setup in your agent to configure the project"
  log "  2. Set up scheduled tasks (heartbeat + morning briefing)"
  log "  3. Start working — use /collalog:log and /collalog:save"
  echo ""
}

# ─── SETUP (CLI fallback — prefer /collalog:setup command) ─────────────────

cmd_setup() {
  if [[ ! -d ".collalog" ]]; then
    error "Not a collalog project. Run 'collalog init' first."
    exit 1
  fi

  log "Project Setup Wizard"
  log "(Tip: For a richer experience, use /collalog:setup in your AI agent)"
  echo ""

  read -rp "Project name: " project_name
  [[ -z "$project_name" ]] && { error "Project name required."; exit 1; }

  read -rp "Short description (1 line): " project_desc

  read -rp "Primary language [en]: " project_lang
  project_lang="${project_lang:-en}"

  echo ""
  info "Team Members (press Enter when done)"
  local -a team_names=()
  local -a team_shorts=()
  local -a team_roles=()
  local i=1
  while true; do
    read -rp "  Member $i name (or Enter to finish): " name
    [[ -z "$name" ]] && break
    read -rp "  Member $i shortcut (e.g., @SG): " shortcut
    read -rp "  Member $i role: " role
    team_names+=("$name")
    team_shorts+=("$shortcut")
    team_roles+=("$role")
    ((i++))
  done

  read -rp "Key technologies (comma-separated): " tech_stack
  read -rp "Communication platform (e.g., Slack, WhatsApp, Teams): " comm_platform

  echo ""
  info "Your Identity (for collalog/me.md — local, gitignored)"
  read -rp "  Your first name: " me_first
  read -rp "  Your last name: " me_last
  read -rp "  Your email: " me_email
  read -rp "  Your shortcut (e.g., @SG): " me_shortcut

  echo ""
  local git_enabled="yes"
  if ! git rev-parse --is-inside-work-tree &>/dev/null; then
    info "No git repository detected."
    read -rp "Use git for version control? [no]: " git_answer
    git_enabled="${git_answer:-no}"
  else
    read -rp "Use git for version control? [yes]: " git_answer
    git_enabled="${git_answer:-yes}"
  fi

  echo ""
  log "Generating project configuration..."

  local agent=$(grep '^agent:' ".collalog/config.yaml" 2>/dev/null | head -1 | awk '{print $2}' | tr -d '"' || echo 'claude')
  local commands_dir=$(grep '^commands_dir:' ".collalog/config.yaml" 2>/dev/null | head -1 | sed 's/^commands_dir: "//' | tr -d '"' || get_commands_dir "$agent")
  local initialized=$(grep '^initialized:' ".collalog/config.yaml" 2>/dev/null | head -1 | sed 's/^initialized: "//' | tr -d '"' || date -Iseconds)
  local template_source=$(grep '^template_source:' ".collalog/config.yaml" 2>/dev/null | head -1 | sed 's/^template_source: "//' | tr -d '"' || echo '')

  local config=".collalog/config.yaml"
  cat > "$config" <<YAML
# collalog configuration
version: "${VERSION}"
agent: "${agent}"
commands_dir: "${commands_dir}"
language: "${project_lang}"
initialized: "${initialized}"
configured: "$(date -Iseconds)"
template_source: "${template_source}"
git_enabled: "${git_enabled}"

project:
  name: "${project_name}"
  description: "${project_desc}"
  language: "${project_lang}"
  technologies: "${tech_stack}"
  communication: "${comm_platform}"
  team:
YAML

  for idx in "${!team_names[@]}"; do
    cat >> "$config" <<YAML
    - name: "${team_names[$idx]}"
      shortcut: "${team_shorts[$idx]}"
      role: "${team_roles[$idx]}"
YAML
  done

  log "Generating files..."
  source "$LIB_DIR/generate.sh"
  generate_claude_md "$config" "CLAUDE.md"
  generate_project_md "$config" "collalog/project.md"
  generate_tasks "$config" "collalog/tasks.md"

  # Generate me.md (local, gitignored)
  if [[ -n "$me_first" || -n "$me_shortcut" ]]; then
    cat > "collalog/me.md" <<ME_INNER
# Me

> This file identifies the current user. It is local and gitignored.
> Must match a team member in project.md.

| Field | Value |
|-------|-------|
| First name | ${me_first} |
| Last name | ${me_last} |
| Email | ${me_email} |
| Shortcut | ${me_shortcut} |
ME_INNER
    info "  + collalog/me.md (local identity)"
  fi

  echo ""
  log "Setup complete! Your project '${project_name}' is ready."
  echo ""
  log "Next steps:"
  log "  1. Review CLAUDE.md and collalog/project.md"
  log "  2. Set up scheduled tasks (heartbeat + morning)"
  if [[ "$git_enabled" == "yes" ]]; then
    log "  3. git add -A && git commit -m 'org: collalog setup complete'"
  fi
}

# ─── UPDATE ────────────────────────────────────────────────────────────────

cmd_update() {
  if [[ ! -d ".collalog" ]]; then
    error "Not a collalog project. Run 'collalog init' first."
    exit 1
  fi

  local config=".collalog/config.yaml"
  local source
  source=$(grep 'template_source:' "$config" | sed 's/.*: "//' | tr -d '"')

  if [[ -z "$source" || ! -d "$source" ]]; then
    error "Template source not found. Set template_source in .collalog/config.yaml"
    exit 1
  fi

  local agent=$(grep '^agent:' "$config" 2>/dev/null | head -1 | awk '{print $2}' | tr -d '"' || echo 'claude')
  local commands_dir=$(grep '^commands_dir:' "$config" 2>/dev/null | head -1 | sed 's/^commands_dir: "//' | tr -d '"' || get_commands_dir "$agent")

  log "Updating from: $source"
  echo ""

  # Update commands in agent dir
  log "Commands ($commands_dir):"
  for cmd in "$source/templates/commands"/*.md; do
    [[ -f "$cmd" ]] || continue
    local base_name=$(basename "$cmd" .md)
    local target_name=$(agent_command_filename "$agent" "$base_name")
    local target="$commands_dir/$target_name"
    local stored=".collalog/templates/commands/$(basename "$cmd")"

    if [[ ! -f "$target" ]]; then
      cp "$cmd" "$target"
      cp "$cmd" "$stored" 2>/dev/null || true
      info "  + $target_name (new)"
    elif [[ -f "$stored" ]] && diff -q "$cmd" "$stored" > /dev/null 2>&1; then
      info "  = $target_name (unchanged)"
    else
      warn "  ~ $target_name (differs — use 'collalog sync' to review)"
    fi
  done

  # Update skills
  echo ""
  log "Skills (.collalog/skills):"
  for skill in "$source/templates/skills"/*.md; do
    [[ -f "$skill" ]] || continue
    local name=$(basename "$skill")
    local target=".collalog/skills/$name"
    local stored=".collalog/templates/skills/$name"

    if [[ ! -f "$target" ]]; then
      cp "$skill" "$target"
      cp "$skill" "$stored" 2>/dev/null || true
      info "  + $name (new)"
    elif [[ -f "$stored" ]] && diff -q "$skill" "$stored" > /dev/null 2>&1; then
      info "  = $name (unchanged)"
    else
      warn "  ~ $name (differs — use 'collalog sync' to review)"
    fi
  done

  # Update prompts
  echo ""
  log "Prompts (.collalog/prompts):"
  for prompt in "$source/templates/prompts"/*.md; do
    [[ -f "$prompt" ]] || continue
    local name=$(basename "$prompt")
    local target=".collalog/prompts/$name"
    local stored=".collalog/templates/prompts/$name"

    if [[ ! -f "$target" ]]; then
      cp "$prompt" "$target"
      cp "$prompt" "$stored" 2>/dev/null || true
      info "  + $name (new)"
    elif [[ -f "$stored" ]] && diff -q "$prompt" "$stored" > /dev/null 2>&1; then
      info "  = $name (unchanged)"
    else
      warn "  ~ $name (differs — use 'collalog sync' to review)"
    fi
  done

  # Update stored templates
  cp "$source/templates/commands"/*.md ".collalog/templates/commands/" 2>/dev/null || true
  cp "$source/templates/skills"/*.md ".collalog/templates/skills/" 2>/dev/null || true
  cp "$source/templates/prompts"/*.md ".collalog/templates/prompts/" 2>/dev/null || true

  echo ""
  log "Update complete."
}

# ─── SYNC ──────────────────────────────────────────────────────────────────

cmd_sync() {
  if [[ ! -d ".collalog" ]]; then
    error "Not a collalog project."
    exit 1
  fi

  local config=".collalog/config.yaml"
  local source
  source=$(grep 'template_source:' "$config" | sed 's/.*: "//' | tr -d '"')

  if [[ -z "$source" || ! -d "$source" ]]; then
    error "Template source not found."
    exit 1
  fi

  local agent=$(grep '^agent:' "$config" 2>/dev/null | head -1 | awk '{print $2}' | tr -d '"' || echo 'claude')
  local commands_dir=$(grep '^commands_dir:' "$config" 2>/dev/null | head -1 | sed 's/^commands_dir: "//' | tr -d '"' || get_commands_dir "$agent")

  log "Comparing project files with templates..."
  echo ""

  local has_diff=false

  # Compare commands
  info "Commands ($commands_dir):"
  for cmd in "$source/templates/commands"/*.md; do
    [[ -f "$cmd" ]] || continue
    local base_name=$(basename "$cmd" .md)
    local target_name=$(agent_command_filename "$agent" "$base_name")
    local target="$commands_dir/$target_name"

    if [[ ! -f "$target" ]]; then
      warn "  [missing] $target_name"
      has_diff=true
    elif diff -q "$cmd" "$target" > /dev/null 2>&1; then
      info "  [ok] $target_name"
    else
      warn "  [modified] $target_name"
      diff --color=always -u "$cmd" "$target" | head -30
      echo ""
      has_diff=true
    fi
  done

  # Compare skills
  echo ""
  info "Skills (.collalog/skills):"
  for skill in "$source/templates/skills"/*.md; do
    [[ -f "$skill" ]] || continue
    local name=$(basename "$skill")
    local target=".collalog/skills/$name"

    if [[ ! -f "$target" ]]; then
      warn "  [missing] $name"
      has_diff=true
    elif diff -q "$skill" "$target" > /dev/null 2>&1; then
      info "  [ok] $name"
    else
      warn "  [modified] $name"
      diff --color=always -u "$skill" "$target" | head -20
      echo ""
      has_diff=true
    fi
  done

  # Compare prompts
  echo ""
  info "Prompts (.collalog/prompts):"
  for prompt in "$source/templates/prompts"/*.md; do
    [[ -f "$prompt" ]] || continue
    local name=$(basename "$prompt")
    local target=".collalog/prompts/$name"

    if [[ ! -f "$target" ]]; then
      warn "  [missing] $name"
      has_diff=true
    elif diff -q "$prompt" "$target" > /dev/null 2>&1; then
      info "  [ok] $name"
    else
      warn "  [modified] $name"
      diff --color=always -u "$prompt" "$target" | head -20
      echo ""
      has_diff=true
    fi
  done

  echo ""
  if [[ "$has_diff" == false ]]; then
    log "Everything in sync."
  else
    log "Use 'collalog update' to pull latest templates."
  fi
}

# ─── MAIN ──────────────────────────────────────────────────────────────────

AGENT="claude"
LANG_OPT="en"

while [[ $# -gt 0 ]]; do
  case "$1" in
    --agent)  AGENT="$2"; shift 2 ;;
    --lang)   LANG_OPT="$2"; shift 2 ;;
    --help)   usage; exit 0 ;;
    *)        break ;;
  esac
done

CMD="${1:-}"
shift || true

case "$CMD" in
  init)     cmd_init "$@" ;;
  setup)    cmd_setup "$@" ;;
  update)   cmd_update "$@" ;;
  sync)     cmd_sync "$@" ;;
  version)  echo "collalog v${VERSION}" ;;
  "")       usage ;;
  *)        error "Unknown command: $CMD"; usage; exit 1 ;;
esac
