#!/usr/bin/env bash
# clawlaborate — Collaborative AI agent setup for teams
# Central unified log + skills for multi-person + agent collaboration
# Inspired by speckit and openspec

set -euo pipefail

VERSION="0.3.0"
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT_DIR="$(dirname "$SCRIPT_DIR")"
TEMPLATES_DIR="$ROOT_DIR/templates"
LIB_DIR="$ROOT_DIR/lib"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
BLUE='\033[0;34m'
YELLOW='\033[1;33m'
NC='\033[0m'

log()   { echo -e "${GREEN}[collalog]${NC} $1"; }
warn()  { echo -e "${YELLOW}[collalog]${NC} $1"; }
error() { echo -e "${RED}[collalog]${NC} $1" >&2; }
info()  { echo -e "${BLUE}[collalog]${NC} $1"; }

# ─── AGENT CONFIGURATIONS ─────────────────────────────────────────────────

declare -A AGENT_COMMANDS_DIR=(
  [claude]=".claude/commands"
  [codex]=".codex/prompts"
  [cursor]=".cursor/commands"
  [gemini]=".gemini/commands"
  [windsurf]=".windsurf/workflows"
  [copilot]=".github/agents"
  [kilo]=".kilocode/workflows"
  [roo]=".roo/commands"
  [opencode]=".opencode/command"
  [kiro]=".kiro/prompts"
  [amp]=".agents/commands"
  [openclaw]=".clawlaborate/skills"
)

agent_skill_filename() {
  local agent="$1" skill_name="$2"
  case "$agent" in
    copilot) echo "collalog.${skill_name}.agent.md" ;;
    gemini)  echo "collalog.${skill_name}.toml" ;;
    *)       echo "collalog.${skill_name}.md" ;;
  esac
}

get_commands_dir() {
  local agent="$1"
  echo "${AGENT_COMMANDS_DIR[$agent]:-".clawlaborate/skills"}"
}

# ─── USAGE ─────────────────────────────────────────────────────────────────

usage() {
  cat <<EOF
clawlaborate v${VERSION} — Collaborative AI agent setup for teams

Usage:
  collalog init [path]          Initialize a new project
  collalog setup                Interactive project configuration
  collalog update               Update skills/prompts from templates
  collalog sync                 Show diff between project and templates
  collalog version              Show version

Options:
  --agent <type>    AI tool: claude (default), codex, cursor, gemini,
                    windsurf, copilot, kilo, roo, opencode, kiro, amp, openclaw
  --lang <lang>     Language for project files: en (default), de
  --help            Show this help

Examples:
  collalog init .                          # Init in current dir (Claude)
  collalog --agent codex init ./project    # Init for Codex
  collalog setup                           # Interactive setup wizard
  collalog update                          # Pull latest templates
EOF
}

# ─── INIT ──────────────────────────────────────────────────────────────────

install_skill() {
  local source_file="$1" target_dir="$2" agent="$3"
  local skill_name=$(basename "$source_file" .md)
  local target_name=$(agent_skill_filename "$agent" "$skill_name")
  local target_file="$target_dir/$target_name"

  if [[ ! -f "$target_file" ]]; then
    cp "$source_file" "$target_file"
    info "  + $(basename "$target_dir")/$target_name"
  else
    warn "  ~ $(basename "$target_dir")/$target_name (exists, skipped)"
  fi
}

cmd_init() {
  local target="${1:-.}"
  local agent="${AGENT:-claude}"
  local lang="${LANG_OPT:-en}"

  if [[ -z "${AGENT_COMMANDS_DIR[$agent]+x}" ]]; then
    error "Unknown agent: $agent"
    error "Supported: ${!AGENT_COMMANDS_DIR[*]}"
    exit 1
  fi

  if [[ ! -d "$target" ]]; then
    mkdir -p "$target"
    log "Created directory: $target"
  fi
  target="$(cd "$target" && pwd)"

  local commands_dir=$(get_commands_dir "$agent")

  log "Initializing clawlaborate in: $target"
  log "Agent: $agent | Commands: $commands_dir | Language: $lang"
  echo ""

  # Create collalog/ — the single user-facing directory
  mkdir -p "$target/collalog"
  info "  + collalog/"

  # Create .clawlaborate/ — fixed elements only (templates, prompts, config)
  mkdir -p "$target/.clawlaborate"/{templates/skills,templates/prompts,prompts}
  info "  + .clawlaborate/"

  # Create agent-specific commands directory
  mkdir -p "$target/$commands_dir"
  info "  + $commands_dir/"

  # Install skills → agent commands directory
  log "Installing skills to $commands_dir..."
  for skill in "$TEMPLATES_DIR/skills"/*.md; do
    [[ -f "$skill" ]] || continue
    install_skill "$skill" "$target/$commands_dir" "$agent"
  done

  # Store original templates for update/sync
  log "Storing templates in .clawlaborate/templates..."
  for skill in "$TEMPLATES_DIR/skills"/*.md; do
    [[ -f "$skill" ]] || continue
    cp "$skill" "$target/.clawlaborate/templates/skills/"
  done
  for prompt in "$TEMPLATES_DIR/prompts"/*.md; do
    [[ -f "$prompt" ]] || continue
    cp "$prompt" "$target/.clawlaborate/templates/prompts/"
  done
  info "  + .clawlaborate/templates/ (originals for sync)"

  # Install prompts → .clawlaborate/prompts/
  log "Installing prompts..."
  for prompt in "$TEMPLATES_DIR/prompts"/*.md; do
    [[ -f "$prompt" ]] || continue
    local name=$(basename "$prompt")
    if [[ ! -f "$target/.clawlaborate/prompts/$name" ]]; then
      cp "$prompt" "$target/.clawlaborate/prompts/$name"
      info "  + .clawlaborate/prompts/$name"
    else
      warn "  ~ .clawlaborate/prompts/$name (exists, skipped)"
    fi
  done

  # Create collalog files from templates
  log "Creating collalog files..."
  for tmpl in "$TEMPLATES_DIR/collalog"/*.md; do
    [[ -f "$tmpl" ]] || continue
    local name=$(basename "$tmpl")
    if [[ ! -f "$target/collalog/$name" ]]; then
      cp "$tmpl" "$target/collalog/$name"
      info "  + collalog/$name"
    else
      warn "  ~ collalog/$name (exists, skipped)"
    fi
  done

  # Copy CLAUDE.md template
  if [[ ! -f "$target/CLAUDE.md" ]]; then
    cp "$TEMPLATES_DIR/CLAUDE.md.template" "$target/CLAUDE.md"
    info "  + CLAUDE.md (template — run 'collalog setup' to configure)"
  else
    warn "  ~ CLAUDE.md (exists, skipped)"
  fi

  # Write config
  cat > "$target/.clawlaborate/config.yaml" <<YAML
# clawlaborate configuration
version: "${VERSION}"
agent: "${agent}"
commands_dir: "${commands_dir}"
language: "${lang}"
initialized: "$(date -Iseconds)"
template_source: "${ROOT_DIR}"

# Project settings (populated by 'collalog setup')
project:
  name: ""
  description: ""
  team: []
YAML

  echo ""
  log "Done! Project initialized with clawlaborate."
  echo ""
  log "Structure:"
  info "  collalog/               Log, tasks, project info (user-facing)"
  info "  $commands_dir/     Skills (agent reads these)"
  info "  .clawlaborate/          Templates, prompts, config (fixed)"
  info "  CLAUDE.md               Main agent prompt"
  echo ""
  log "Next steps:"
  log "  1. cd $target"
  log "  2. collalog setup    # Configure project details"
  log "  3. Set up scheduled tasks (heartbeat + morning briefing)"
  echo ""
}

# ─── SETUP ─────────────────────────────────────────────────────────────────

cmd_setup() {
  if [[ ! -d ".clawlaborate" ]]; then
    error "Not a clawlaborate project. Run 'collalog init' first."
    exit 1
  fi

  log "Project Setup Wizard"
  echo ""

  read -rp "Project name: " project_name
  [[ -z "$project_name" ]] && { error "Project name required."; exit 1; }

  read -rp "Short description (1 line): " project_desc

  read -rp "Primary language [en]: " project_lang
  project_lang="${project_lang:-en}"

  echo ""
  info "Team Members (press Enter when done)"
  local -a team_names=()
  local -a team_shorts=()
  local -a team_roles=()
  local i=1
  while true; do
    read -rp "  Member $i name (or Enter to finish): " name
    [[ -z "$name" ]] && break
    read -rp "  Member $i shortcut (e.g., @SG): " shortcut
    read -rp "  Member $i role: " role
    team_names+=("$name")
    team_shorts+=("$shortcut")
    team_roles+=("$role")
    ((i++))
  done

  read -rp "Key technologies (comma-separated): " tech_stack
  read -rp "Communication platform (e.g., Slack, WhatsApp, Teams): " comm_platform

  echo ""
  log "Generating project configuration..."

  local agent=$(grep '^agent:' ".clawlaborate/config.yaml" 2>/dev/null | head -1 | awk '{print $2}' | tr -d '"' || echo 'claude')
  local commands_dir=$(grep '^commands_dir:' ".clawlaborate/config.yaml" 2>/dev/null | head -1 | sed 's/^commands_dir: "//' | tr -d '"' || get_commands_dir "$agent")
  local initialized=$(grep '^initialized:' ".clawlaborate/config.yaml" 2>/dev/null | head -1 | sed 's/^initialized: "//' | tr -d '"' || date -Iseconds)
  local template_source=$(grep '^template_source:' ".clawlaborate/config.yaml" 2>/dev/null | head -1 | sed 's/^template_source: "//' | tr -d '"' || echo '')

  local config=".clawlaborate/config.yaml"
  cat > "$config" <<YAML
# clawlaborate configuration
version: "${VERSION}"
agent: "${agent}"
commands_dir: "${commands_dir}"
language: "${project_lang}"
initialized: "${initialized}"
configured: "$(date -Iseconds)"
template_source: "${template_source}"

project:
  name: "${project_name}"
  description: "${project_desc}"
  language: "${project_lang}"
  technologies: "${tech_stack}"
  communication: "${comm_platform}"
  team:
YAML

  for idx in "${!team_names[@]}"; do
    cat >> "$config" <<YAML
    - name: "${team_names[$idx]}"
      shortcut: "${team_shorts[$idx]}"
      role: "${team_roles[$idx]}"
YAML
  done

  # Generate files from config
  log "Generating files..."
  source "$LIB_DIR/generate.sh"
  generate_claude_md "$config" "CLAUDE.md"
  generate_project_md "$config" "collalog/project.md"
  generate_tasks "$config" "collalog/tasks.md"

  echo ""
  log "Setup complete!"
  log "Your project '${project_name}' is ready."
  echo ""
  log "Files generated:"
  info "  CLAUDE.md               Main agent prompt"
  info "  collalog/project.md     Project description + team"
  info "  collalog/tasks.md       Task list"
  info "  collalog/log.md         Unified log (ready for entries)"
  echo ""
  log "Next steps:"
  log "  1. Review and customize CLAUDE.md"
  log "  2. Set up scheduled tasks:"
  log "     - Heartbeat: every 30 min (see .clawlaborate/prompts/heartbeat.md)"
  log "     - Morning briefing: daily at 8:00 (see .clawlaborate/prompts/morning.md)"
  log "  3. git add -A && git commit -m 'org: initialize project with clawlaborate'"
}

# ─── UPDATE ────────────────────────────────────────────────────────────────

cmd_update() {
  if [[ ! -d ".clawlaborate" ]]; then
    error "Not a clawlaborate project. Run 'collalog init' first."
    exit 1
  fi

  local config=".clawlaborate/config.yaml"
  local source
  source=$(grep 'template_source:' "$config" | sed 's/.*: "//' | tr -d '"')

  if [[ -z "$source" || ! -d "$source" ]]; then
    error "Template source not found. Set template_source in .clawlaborate/config.yaml"
    exit 1
  fi

  local agent=$(grep '^agent:' "$config" 2>/dev/null | head -1 | awk '{print $2}' | tr -d '"' || echo 'claude')
  local commands_dir=$(grep '^commands_dir:' "$config" 2>/dev/null | head -1 | sed 's/^commands_dir: "//' | tr -d '"' || get_commands_dir "$agent")

  log "Updating from: $source"
  log "Agent: $agent | Commands: $commands_dir"
  echo ""

  log "Skills ($commands_dir):"
  for skill in "$source/templates/skills"/*.md; do
    [[ -f "$skill" ]] || continue
    local skill_name=$(basename "$skill" .md)
    local target_name=$(agent_skill_filename "$agent" "$skill_name")
    local target="$commands_dir/$target_name"
    local stored=".clawlaborate/templates/skills/$(basename "$skill")"

    if [[ ! -f "$target" ]]; then
      cp "$skill" "$target"
      cp "$skill" "$stored" 2>/dev/null || true
      info "  + $target_name (new)"
    elif [[ -f "$stored" ]] && diff -q "$skill" "$stored" > /dev/null 2>&1; then
      info "  = $target_name (unchanged)"
    elif diff -q "$skill" "$target" > /dev/null 2>&1; then
      cp "$skill" "$stored" 2>/dev/null || true
      info "  = $target_name (up to date)"
    else
      warn "  ~ $target_name (differs — use 'collalog sync' to review)"
    fi
  done

  echo ""
  log "Prompts (.clawlaborate/prompts):"
  for prompt in "$source/templates/prompts"/*.md; do
    [[ -f "$prompt" ]] || continue
    local name=$(basename "$prompt")
    local target=".clawlaborate/prompts/$name"
    local stored=".clawlaborate/templates/prompts/$name"

    if [[ ! -f "$target" ]]; then
      cp "$prompt" "$target"
      cp "$prompt" "$stored" 2>/dev/null || true
      info "  + $name (new)"
    elif [[ -f "$stored" ]] && diff -q "$prompt" "$stored" > /dev/null 2>&1; then
      info "  = $name (unchanged)"
    else
      warn "  ~ $name (differs — use 'collalog sync' to review)"
    fi
  done

  cp "$source/templates/skills"/*.md ".clawlaborate/templates/skills/" 2>/dev/null || true
  cp "$source/templates/prompts"/*.md ".clawlaborate/templates/prompts/" 2>/dev/null || true

  echo ""
  log "Update complete."
}

# ─── SYNC ──────────────────────────────────────────────────────────────────

cmd_sync() {
  if [[ ! -d ".clawlaborate" ]]; then
    error "Not a clawlaborate project."
    exit 1
  fi

  local config=".clawlaborate/config.yaml"
  local source
  source=$(grep 'template_source:' "$config" | sed 's/.*: "//' | tr -d '"')

  if [[ -z "$source" || ! -d "$source" ]]; then
    error "Template source not found."
    exit 1
  fi

  local agent=$(grep '^agent:' "$config" 2>/dev/null | head -1 | awk '{print $2}' | tr -d '"' || echo 'claude')
  local commands_dir=$(grep '^commands_dir:' "$config" 2>/dev/null | head -1 | sed 's/^commands_dir: "//' | tr -d '"' || get_commands_dir "$agent")

  log "Comparing project files with templates..."
  echo ""

  local has_diff=false

  info "Skills ($commands_dir):"
  for skill in "$source/templates/skills"/*.md; do
    [[ -f "$skill" ]] || continue
    local skill_name=$(basename "$skill" .md)
    local target_name=$(agent_skill_filename "$agent" "$skill_name")
    local target="$commands_dir/$target_name"

    if [[ ! -f "$target" ]]; then
      warn "  [missing] $target_name"
      has_diff=true
    elif diff -q "$skill" "$target" > /dev/null 2>&1; then
      info "  [ok] $target_name"
    else
      warn "  [modified] $target_name"
      diff --color=always -u "$skill" "$target" | head -30
      echo "  ..."
      echo ""
      has_diff=true
    fi
  done

  for file in "$commands_dir"/collalog.*; do
    [[ -f "$file" ]] || continue
    local name=$(basename "$file")
    local skill_name=$(echo "$name" | sed 's/^collalog\.\(.*\)\.\(md\|toml\|agent\.md\)$/\1/')
    if [[ ! -f "$source/templates/skills/${skill_name}.md" ]]; then
      info "  [project-only] $name"
    fi
  done

  echo ""
  info "Prompts (.clawlaborate/prompts):"
  for prompt in "$source/templates/prompts"/*.md; do
    [[ -f "$prompt" ]] || continue
    local name=$(basename "$prompt")
    local target=".clawlaborate/prompts/$name"

    if [[ ! -f "$target" ]]; then
      warn "  [missing] $name"
      has_diff=true
    elif diff -q "$prompt" "$target" > /dev/null 2>&1; then
      info "  [ok] $name"
    else
      warn "  [modified] $name"
      diff --color=always -u "$prompt" "$target" | head -20
      echo "  ..."
      echo ""
      has_diff=true
    fi
  done

  echo ""
  if [[ "$has_diff" == false ]]; then
    log "Everything in sync."
  else
    log "Use 'collalog update' to pull latest templates."
  fi
}

# ─── MAIN ──────────────────────────────────────────────────────────────────

AGENT="claude"
LANG_OPT="en"

while [[ $# -gt 0 ]]; do
  case "$1" in
    --agent)  AGENT="$2"; shift 2 ;;
    --lang)   LANG_OPT="$2"; shift 2 ;;
    --help)   usage; exit 0 ;;
    *)        break ;;
  esac
done

CMD="${1:-}"
shift || true

case "$CMD" in
  init)     cmd_init "$@" ;;
  setup)    cmd_setup "$@" ;;
  update)   cmd_update "$@" ;;
  sync)     cmd_sync "$@" ;;
  version)  echo "clawlaborate v${VERSION}" ;;
  "")       usage ;;
  *)        error "Unknown command: $CMD"; usage; exit 1 ;;
esac
