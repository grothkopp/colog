#!/usr/bin/env bash
# colog — Collaborative logging for AI-assisted teams
# Central unified log + commands/skills/prompts for multi-person + agent collaboration

set -euo pipefail

VERSION="0.7.2"
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT_DIR="$(dirname "$SCRIPT_DIR")"
TEMPLATES_DIR="$ROOT_DIR/templates"
LIB_DIR="$ROOT_DIR/lib"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
BLUE='\033[0;34m'
YELLOW='\033[1;33m'
NC='\033[0m'

log()   { echo -e "${GREEN}[colog]${NC} $1"; }
warn()  { echo -e "${YELLOW}[colog]${NC} $1"; }
error() { echo -e "${RED}[colog]${NC} $1" >&2; }
info()  { echo -e "${BLUE}[colog]${NC} $1"; }

# ─── AGENT CONFIGURATIONS ─────────────────────────────────────────────────

declare -A AGENT_COMMANDS_DIR=(
  [claude]=".claude/commands"
  [codex]=".codex/prompts"
  [cursor]=".cursor/commands"
  [gemini]=".gemini/commands"
  [windsurf]=".windsurf/workflows"
  [copilot]=".github/agents"
  [kilo]=".kilocode/workflows"
  [roo]=".roo/commands"
  [opencode]=".opencode/command"
  [kiro]=".kiro/prompts"
  [amp]=".agents/commands"
  [openclaw]=".colog/commands"
)

agent_command_filename() {
  local agent="$1" name="$2"
  case "$agent" in
    copilot) echo "${name}.agent.md" ;;
    gemini)  echo "${name}.toml" ;;
    *)       echo "${name}.md" ;;
  esac
}

get_commands_dir() {
  local agent="$1"
  echo "${AGENT_COMMANDS_DIR[$agent]:-".colog/commands"}"
}

# ─── USAGE ─────────────────────────────────────────────────────────────────

usage() {
  cat <<EOF
colog v${VERSION} — Collaborative logging for AI-assisted teams

Usage:
  colog init [path]          Initialize a new project
  colog setup                Interactive project configuration
  colog update               Update commands/skills/prompts from templates
  colog sync                 Show diff between project and templates
  colog version              Show version

Options:
  --agent <type>    AI tool: claude (default), codex, cursor, gemini,
                    windsurf, copilot, kilo, roo, opencode, kiro, amp, openclaw
  --lang <lang>     Language for project files: en (default), de
  --help            Show this help

After init, use these agent commands:
  /colog:setup               Project setup wizard (one-time)
  /colog:log <description>   Add a log entry manually
  /colog:save [description]  Save current work (log + commit)
  /colog:status              Project overview

Examples:
  colog init .
  colog --agent codex init ./project
  colog setup
EOF
}

# ─── AGENT PERMISSIONS ─────────────────────────────────────────────────────

configure_agent_permissions() {
  local target="$1" agent="$2"

  case "$agent" in
    claude)
      # Claude Code: .claude/settings.json with allow/deny rules
      local settings_file="$target/.claude/settings.json"
      local colog_rules=(
        'Bash(git status)'
        'Bash(git log *)'
        'Bash(git diff *)'
        'Bash(git add *)'
        'Bash(git commit *)'
        'Bash(git fetch *)'
        'Bash(git pull *)'
        'Bash(git push)'
        'Bash(git push *)'
        'Bash(git branch *)'
        'Bash(git checkout *)'
        'Bash(git merge *)'
        'Bash(git rebase *)'
        'Bash(git rev-parse *)'
        'Bash(git remote *)'
        'Bash(git shortlog *)'
        'Bash(git show *)'
        'Bash(git stash *)'
      )

      # Build the JSON array of rules (reused below)
      local rules_json
      rules_json=$(printf '      "%s"' "${colog_rules[0]}"
        for rule in "${colog_rules[@]:1}"; do
          printf ',\n      "%s"' "$rule"
        done)

      mkdir -p "$target/.claude"

      if [[ ! -f "$settings_file" ]]; then
        # No settings file — create fresh
        cat > "$settings_file" <<SETTINGS_JSON
{
  "permissions": {
    "allow": [
${rules_json}
    ]
  }
}
SETTINGS_JSON
        info "  + .claude/settings.json (git permissions for colog)"

      else
        # Settings file exists — check if all rules are already present
        local missing=0
        for rule in "${colog_rules[@]}"; do
          if ! grep -qF "\"$rule\"" "$settings_file"; then
            ((missing++))
          fi
        done

        if [[ $missing -eq 0 ]]; then
          info "  = .claude/settings.json (git permissions already present)"
        else
          # Need to merge — try python3, then node, then sed fallback
          local merged=false

          if command -v python3 &>/dev/null; then
            python3 << 'PYEOF' "$settings_file" "${colog_rules[@]}" && merged=true
import json, sys
settings_file = sys.argv[1]
new_rules = sys.argv[2:]
with open(settings_file, 'r') as f:
    data = json.load(f)
data.setdefault('permissions', {}).setdefault('allow', [])
existing = set(data['permissions']['allow'])
for rule in new_rules:
    if rule not in existing:
        data['permissions']['allow'].append(rule)
with open(settings_file, 'w') as f:
    json.dump(data, f, indent=2)
    f.write('\n')
PYEOF

          elif command -v node &>/dev/null; then
            node -e "
const fs = require('fs');
const f = process.argv[1];
const rules = process.argv.slice(2);
const data = JSON.parse(fs.readFileSync(f, 'utf8'));
if (!data.permissions) data.permissions = {};
if (!data.permissions.allow) data.permissions.allow = [];
const existing = new Set(data.permissions.allow);
for (const r of rules) { if (!existing.has(r)) data.permissions.allow.push(r); }
fs.writeFileSync(f, JSON.stringify(data, null, 2) + '\n');
" "$settings_file" "${colog_rules[@]}" && merged=true
          fi

          if [[ "$merged" == true ]]; then
            info "  ~ .claude/settings.json (added colog git permissions)"
          else
            # Pure-bash fallback: find the allow array closing bracket and
            # insert new rules before it. Works for standard formatted JSON.
            if grep -q '"allow"' "$settings_file"; then
              # Build insert text: new rules as JSON strings
              local insert_lines=""
              for rule in "${colog_rules[@]}"; do
                if ! grep -qF "\"$rule\"" "$settings_file"; then
                  insert_lines="${insert_lines},\n      \"$rule\""
                fi
              done
              if [[ -n "$insert_lines" ]]; then
                # Find the last entry in the allow array and append after it
                # Strategy: replace the last line before ] in the allow block
                sed -i -E '/^\s*"Bash\(/!b; :a; N; /\n\s*\]/!ba; s/("Bash\([^"]*\)")/\1'"$(echo -e "$insert_lines")"'/' "$settings_file" 2>/dev/null \
                  && info "  ~ .claude/settings.json (added colog git permissions)" \
                  || warn "  ! .claude/settings.json (could not merge — add git permissions manually)"
              fi
            else
              # No allow array at all — warn but don't break
              warn "  ! .claude/settings.json (no allow section — add git permissions manually)"
            fi
          fi
        fi
      fi
      ;;

    codex)
      # OpenAI Codex CLI: uses CODEX.md or codex.json for config
      # Codex has a --full-auto flag but no per-command permission file yet
      info "  (Codex: grant git permissions via --full-auto flag or approval prompts)"
      ;;

    cursor)
      # Cursor: no per-command permission config, uses interactive approval
      info "  (Cursor: git commands will be approved interactively)"
      ;;

    *)
      # Other agents: no known permission config
      info "  (Agent permissions: configure git access per your agent's documentation)"
      ;;
  esac
}

# ─── INIT ──────────────────────────────────────────────────────────────────

install_file() {
  local source_file="$1" target_dir="$2" agent="$3"
  local base_name=$(basename "$source_file" .md)
  local target_name=$(agent_command_filename "$agent" "$base_name")
  local target_file="$target_dir/$target_name"

  if [[ ! -f "$target_file" ]]; then
    cp "$source_file" "$target_file"
    info "  + $(basename "$target_dir")/$target_name"
  else
    warn "  ~ $(basename "$target_dir")/$target_name (exists, skipped)"
  fi
}

cmd_init() {
  local target="${1:-.}"
  local agent="${AGENT:-claude}"
  local lang="${LANG_OPT:-en}"

  if [[ -z "${AGENT_COMMANDS_DIR[$agent]+x}" ]]; then
    error "Unknown agent: $agent"
    error "Supported: ${!AGENT_COMMANDS_DIR[*]}"
    exit 1
  fi

  if [[ ! -d "$target" ]]; then
    mkdir -p "$target"
    log "Created directory: $target"
  fi
  target="$(cd "$target" && pwd)"

  # Ensure we're in a git repository
  if ! git -C "$target" rev-parse --is-inside-work-tree &>/dev/null; then
    echo ""
    warn "No git repository found in: $target"
    echo ""
    info "  1) Initialize a new git repo here"
    info "  2) Clone an existing remote repo"
    echo ""
    read -rp "Choose [1/2]: " git_choice

    case "${git_choice:-1}" in
      2)
        read -rp "Remote URL (e.g., https://github.com/user/repo.git): " remote_url
        if [[ -z "$remote_url" ]]; then
          error "No URL provided. Aborting."
          exit 1
        fi
        log "Cloning $remote_url into $target..."
        git clone "$remote_url" "$target.tmp"
        # Move cloned contents into target (which may already have files)
        mv "$target.tmp/.git" "$target/.git"
        # Copy any cloned files that don't conflict
        shopt -s dotglob
        for f in "$target.tmp"/*; do
          local fname=$(basename "$f")
          [[ "$fname" == ".git" ]] && continue
          if [[ ! -e "$target/$fname" ]]; then
            mv "$f" "$target/"
          fi
        done
        shopt -u dotglob
        rm -rf "$target.tmp"
        log "Repository cloned successfully."
        ;;
      *)
        git -C "$target" init
        log "Git repository initialized."
        # Stage any existing files
        local existing_files
        existing_files=$(git -C "$target" ls-files --others --exclude-standard 2>/dev/null | head -5)
        if [[ -n "$existing_files" ]]; then
          local file_count
          file_count=$(git -C "$target" ls-files --others --exclude-standard 2>/dev/null | wc -l)
          info "Found $file_count existing file(s) in the directory."
          read -rp "Add existing files to the initial commit? [yes]: " add_existing
          if [[ "${add_existing:-yes}" != "no" ]]; then
            git -C "$target" add -A
            git -C "$target" commit -m "change(init): add existing project files"
            log "Existing files committed."
          fi
        fi
        ;;
    esac
  else
    info "Git repository detected."
  fi

  local commands_dir=$(get_commands_dir "$agent")

  log "Initializing colog in: $target"
  log "Agent: $agent | Commands: $commands_dir | Language: $lang"
  echo ""

  # Create colog/ — the single user-facing directory
  mkdir -p "$target/colog"
  info "  + colog/"

  # Create .colog/ — fixed elements (skills, prompts, templates, config)
  mkdir -p "$target/.colog"/{skills,prompts,templates/commands,templates/skills,templates/prompts}
  info "  + .colog/"

  # Create agent-specific commands directory
  mkdir -p "$target/$commands_dir"
  info "  + $commands_dir/"

  # Install COMMANDS → agent commands directory (user-invokable)
  log "Installing commands to $commands_dir..."
  for cmd in "$TEMPLATES_DIR/commands"/*.md; do
    [[ -f "$cmd" ]] || continue
    install_file "$cmd" "$target/$commands_dir" "$agent"
  done

  # Install SKILLS → .colog/skills/ (agent rules, always active)
  log "Installing skills to .colog/skills..."
  for skill in "$TEMPLATES_DIR/skills"/*.md; do
    [[ -f "$skill" ]] || continue
    local name=$(basename "$skill")
    if [[ ! -f "$target/.colog/skills/$name" ]]; then
      cp "$skill" "$target/.colog/skills/$name"
      info "  + .colog/skills/$name"
    else
      warn "  ~ .colog/skills/$name (exists, skipped)"
    fi
  done

  # Install PROMPTS → .colog/prompts/ (scheduled behaviors)
  log "Installing prompts to .colog/prompts..."
  for prompt in "$TEMPLATES_DIR/prompts"/*.md; do
    [[ -f "$prompt" ]] || continue
    local name=$(basename "$prompt")
    if [[ ! -f "$target/.colog/prompts/$name" ]]; then
      cp "$prompt" "$target/.colog/prompts/$name"
      info "  + .colog/prompts/$name"
    else
      warn "  ~ .colog/prompts/$name (exists, skipped)"
    fi
  done

  # Store original templates for update/sync
  log "Storing templates..."
  cp "$TEMPLATES_DIR/commands"/*.md "$target/.colog/templates/commands/" 2>/dev/null || true
  cp "$TEMPLATES_DIR/skills"/*.md "$target/.colog/templates/skills/" 2>/dev/null || true
  cp "$TEMPLATES_DIR/prompts"/*.md "$target/.colog/templates/prompts/" 2>/dev/null || true
  info "  + .colog/templates/ (originals for sync)"

  # Create colog data files from templates (skip me.md — it's local-only, created during setup)
  log "Creating colog files..."
  for tmpl in "$TEMPLATES_DIR/colog"/*.md; do
    [[ -f "$tmpl" ]] || continue
    local name=$(basename "$tmpl")
    [[ "$name" == "me.md" ]] && continue
    if [[ ! -f "$target/colog/$name" ]]; then
      cp "$tmpl" "$target/colog/$name"
      info "  + colog/$name"
    else
      warn "  ~ colog/$name (exists, skipped)"
    fi
  done

  # Create .gitignore with local-only files
  local gitignore="$target/.gitignore"
  local me_entry="colog/me.md"
  if [[ ! -f "$gitignore" ]]; then
    cat > "$gitignore" <<GITIGNORE
# colog — local-only files (not shared via git)
colog/me.md
GITIGNORE
    info "  + .gitignore (with colog/me.md)"
  elif ! grep -qF "$me_entry" "$gitignore"; then
    echo "" >> "$gitignore"
    echo "# colog — local-only files" >> "$gitignore"
    echo "colog/me.md" >> "$gitignore"
    info "  ~ .gitignore (added colog/me.md)"
  fi

  # CLAUDE.md handling — extend existing, never overwrite
  if [[ ! -f "$target/CLAUDE.md" ]]; then
    cp "$TEMPLATES_DIR/CLAUDE.md.template" "$target/CLAUDE.md"
    info "  + CLAUDE.md (template — run '/colog:setup' to configure)"
  elif grep -q "<!-- colog:start -->" "$target/CLAUDE.md"; then
    warn "  ~ CLAUDE.md (colog section exists, skipped)"
  else
    # Append colog section from template to existing CLAUDE.md
    echo "" >> "$target/CLAUDE.md"
    sed -n '/<!-- colog:start -->/,/<!-- colog:end -->/p' "$TEMPLATES_DIR/CLAUDE.md.template" >> "$target/CLAUDE.md"
    info "  ~ CLAUDE.md (appended colog section to existing file)"
  fi

  # Configure agent permissions (allow git commands without prompts)
  configure_agent_permissions "$target" "$agent"

  # Write config
  cat > "$target/.colog/config.yaml" <<YAML
# colog configuration
version: "${VERSION}"
agent: "${agent}"
commands_dir: "${commands_dir}"
language: "${lang}"
initialized: "$(date -Iseconds)"
template_source: "${ROOT_DIR}"

# Project settings (populated by /colog:setup)
project:
  name: ""
  description: ""
  team: []
YAML

  echo ""
  log "Done! Project initialized."
  echo ""
  log "What was installed:"
  info "  colog/               Tasks, project (user-facing data)"
  info "  $commands_dir/     Commands (user invokes these)"
  info "  .colog/skills/       Skills (agent rules, always active)"
  info "  .colog/prompts/      Prompts (scheduled behaviors)"
  info "  CLAUDE.md               Main agent prompt"
  echo ""
  log "Next steps:"
  log "  1. Run /colog:setup in your agent to configure the project"
  log "  2. Set up scheduled tasks (heartbeat + morning briefing)"
  log "  3. Start working — use /colog:log and /colog:save"
  echo ""
}

# ─── SETUP (CLI fallback — prefer /colog:setup command) ─────────────────

cmd_setup() {
  if [[ ! -d ".colog" ]]; then
    error "Not a colog project. Run 'colog init' first."
    exit 1
  fi

  source "$LIB_DIR/generate.sh"

  local config=".colog/config.yaml"
  local is_reconfigure=false

  # Read existing values as defaults
  local existing_name=$(yaml_val "$config" "name")
  local existing_desc=$(yaml_val "$config" "description")
  local existing_lang=$(yaml_val "$config" "language")
  local existing_tech=$(yaml_val "$config" "technologies")
  local existing_comm=$(yaml_val "$config" "communication")

  if [[ -n "$existing_name" ]]; then
    is_reconfigure=true
    log "Project Reconfiguration"
    log "(Tip: Press Enter to keep current values)"
    echo ""
    info "Current configuration:"
    info "  Name: ${existing_name}"
    info "  Description: ${existing_desc}"
    info "  Language: ${existing_lang:-en}"
    info "  Technologies: ${existing_tech}"
    info "  Communication: ${existing_comm}"
    echo ""
  else
    log "Project Setup Wizard"
    log "(Tip: For a richer experience, use /colog:setup in your AI agent)"
    echo ""
  fi

  read -rp "Project name [${existing_name:-}]: " project_name
  project_name="${project_name:-$existing_name}"
  [[ -z "$project_name" ]] && { error "Project name required."; exit 1; }

  read -rp "Short description [${existing_desc:-}]: " project_desc
  project_desc="${project_desc:-$existing_desc}"

  read -rp "Primary language [${existing_lang:-en}]: " project_lang
  project_lang="${project_lang:-${existing_lang:-en}}"

  echo ""
  if [[ "$is_reconfigure" == true ]]; then
    info "Team Members (current team shown below, press Enter to keep, or add new members)"
    # Show existing team
    local existing_team
    existing_team=$(get_team "$config")
    if [[ -n "$existing_team" ]]; then
      while IFS='|' read -r tname tshort trole; do
        [[ -z "$tname" ]] && continue
        tname=$(echo "$tname" | xargs)
        tshort=$(echo "$tshort" | xargs)
        trole=$(echo "$trole" | xargs)
        info "  • ${tname} (${tshort}) — ${trole}"
      done <<< "$existing_team"
    fi
    echo ""
    read -rp "Keep current team? [yes] (no = re-enter): " keep_team
  fi

  local -a team_names=()
  local -a team_shorts=()
  local -a team_roles=()

  if [[ "$is_reconfigure" == true && "${keep_team:-yes}" != "no" ]]; then
    # Preserve existing team
    while IFS='|' read -r tname tshort trole; do
      [[ -z "$tname" ]] && continue
      team_names+=("$(echo "$tname" | xargs)")
      team_shorts+=("$(echo "$tshort" | xargs)")
      team_roles+=("$(echo "$trole" | xargs)")
    done <<< "$(get_team "$config")"
    info "Add more members (press Enter when done):"
  else
    info "Team Members (press Enter when done)"
  fi

  local i=$(( ${#team_names[@]} + 1 ))
  while true; do
    read -rp "  Member $i name (or Enter to finish): " name
    [[ -z "$name" ]] && break
    read -rp "  Member $i shortcut (e.g., @SG): " shortcut
    read -rp "  Member $i role: " role
    team_names+=("$name")
    team_shorts+=("$shortcut")
    team_roles+=("$role")
    ((i++))
  done

  read -rp "Key technologies [${existing_tech:-}]: " tech_stack
  tech_stack="${tech_stack:-$existing_tech}"

  read -rp "Communication platform [${existing_comm:-}]: " comm_platform
  comm_platform="${comm_platform:-$existing_comm}"

  echo ""
  # Only ask for me.md if it doesn't exist yet
  local me_first="" me_last="" me_email="" me_shortcut=""
  if [[ ! -f "colog/me.md" ]]; then
    info "Your Identity (for colog/me.md — local, gitignored)"
    read -rp "  Your first name: " me_first
    read -rp "  Your last name: " me_last
    read -rp "  Your email: " me_email
    read -rp "  Your shortcut (e.g., @SG): " me_shortcut
    echo ""
  else
    info "colog/me.md exists, keeping current identity."
    echo ""
  fi

  echo ""
  log "Generating project configuration..."

  local agent=$(grep '^agent:' "$config" 2>/dev/null | head -1 | awk '{print $2}' | tr -d '"' || echo 'claude')
  local commands_dir=$(grep '^commands_dir:' "$config" 2>/dev/null | head -1 | sed 's/^commands_dir: "//' | tr -d '"' || get_commands_dir "$agent")
  local initialized=$(grep '^initialized:' "$config" 2>/dev/null | head -1 | sed 's/^initialized: "//' | tr -d '"' || date -Iseconds)
  local template_source=$(grep '^template_source:' "$config" 2>/dev/null | head -1 | sed 's/^template_source: "//' | tr -d '"' || echo '')

  cat > "$config" <<YAML
# colog configuration
version: "${VERSION}"
agent: "${agent}"
commands_dir: "${commands_dir}"
language: "${project_lang}"
initialized: "${initialized}"
configured: "$(date -Iseconds)"
template_source: "${template_source}"

project:
  name: "${project_name}"
  description: "${project_desc}"
  language: "${project_lang}"
  technologies: "${tech_stack}"
  communication: "${comm_platform}"
  team:
YAML

  for idx in "${!team_names[@]}"; do
    cat >> "$config" <<YAML
    - name: "${team_names[$idx]}"
      shortcut: "${team_shorts[$idx]}"
      role: "${team_roles[$idx]}"
YAML
  done

  log "Generating files..."
  generate_claude_md "$config" "CLAUDE.md"
  generate_project_md "$config" "colog/project.md"
  generate_tasks "$config" "colog/tasks.md"

  # Generate me.md (local, gitignored)
  if [[ -n "$me_first" || -n "$me_shortcut" ]]; then
    cat > "colog/me.md" <<ME_INNER
# Me

> This file identifies the current user. It is local and gitignored.
> Must match a team member in project.md.

| Field | Value |
|-------|-------|
| First name | ${me_first} |
| Last name | ${me_last} |
| Email | ${me_email} |
| Shortcut | ${me_shortcut} |
ME_INNER
    info "  + colog/me.md (local identity)"
  fi

  echo ""
  log "Setup complete! Your project '${project_name}' is ready."
  echo ""
  log "Next steps:"
  log "  1. Review CLAUDE.md and colog/project.md"
  log "  2. Set up scheduled tasks (heartbeat + morning)"
  log "  3. git add -A && git commit -m 'change(colog): setup complete @Agent'"
}

# ─── UPDATE ────────────────────────────────────────────────────────────────

cmd_update() {
  if [[ ! -d ".colog" ]]; then
    error "Not a colog project. Run 'colog init' first."
    exit 1
  fi

  local config=".colog/config.yaml"
  local source
  source=$(grep 'template_source:' "$config" | sed 's/.*: "//' | tr -d '"')

  if [[ -z "$source" || ! -d "$source" ]]; then
    error "Template source not found. Set template_source in .colog/config.yaml"
    exit 1
  fi

  local agent=$(grep '^agent:' "$config" 2>/dev/null | head -1 | awk '{print $2}' | tr -d '"' || echo 'claude')
  local commands_dir=$(grep '^commands_dir:' "$config" 2>/dev/null | head -1 | sed 's/^commands_dir: "//' | tr -d '"' || get_commands_dir "$agent")

  log "Updating from: $source"
  echo ""

  # Update commands in agent dir
  log "Commands ($commands_dir):"
  for cmd in "$source/templates/commands"/*.md; do
    [[ -f "$cmd" ]] || continue
    local base_name=$(basename "$cmd" .md)
    local target_name=$(agent_command_filename "$agent" "$base_name")
    local target="$commands_dir/$target_name"
    local stored=".colog/templates/commands/$(basename "$cmd")"

    if [[ ! -f "$target" ]]; then
      cp "$cmd" "$target"
      cp "$cmd" "$stored" 2>/dev/null || true
      info "  + $target_name (new)"
    elif [[ -f "$stored" ]] && diff -q "$cmd" "$stored" > /dev/null 2>&1; then
      info "  = $target_name (unchanged)"
    else
      warn "  ~ $target_name (differs — use 'colog sync' to review)"
    fi
  done

  # Update skills
  echo ""
  log "Skills (.colog/skills):"
  for skill in "$source/templates/skills"/*.md; do
    [[ -f "$skill" ]] || continue
    local name=$(basename "$skill")
    local target=".colog/skills/$name"
    local stored=".colog/templates/skills/$name"

    if [[ ! -f "$target" ]]; then
      cp "$skill" "$target"
      cp "$skill" "$stored" 2>/dev/null || true
      info "  + $name (new)"
    elif [[ -f "$stored" ]] && diff -q "$skill" "$stored" > /dev/null 2>&1; then
      info "  = $name (unchanged)"
    else
      warn "  ~ $name (differs — use 'colog sync' to review)"
    fi
  done

  # Update prompts
  echo ""
  log "Prompts (.colog/prompts):"
  for prompt in "$source/templates/prompts"/*.md; do
    [[ -f "$prompt" ]] || continue
    local name=$(basename "$prompt")
    local target=".colog/prompts/$name"
    local stored=".colog/templates/prompts/$name"

    if [[ ! -f "$target" ]]; then
      cp "$prompt" "$target"
      cp "$prompt" "$stored" 2>/dev/null || true
      info "  + $name (new)"
    elif [[ -f "$stored" ]] && diff -q "$prompt" "$stored" > /dev/null 2>&1; then
      info "  = $name (unchanged)"
    else
      warn "  ~ $name (differs — use 'colog sync' to review)"
    fi
  done

  # Update stored templates
  cp "$source/templates/commands"/*.md ".colog/templates/commands/" 2>/dev/null || true
  cp "$source/templates/skills"/*.md ".colog/templates/skills/" 2>/dev/null || true
  cp "$source/templates/prompts"/*.md ".colog/templates/prompts/" 2>/dev/null || true

  echo ""
  log "Update complete."
}

# ─── SYNC ──────────────────────────────────────────────────────────────────

cmd_sync() {
  if [[ ! -d ".colog" ]]; then
    error "Not a colog project."
    exit 1
  fi

  local config=".colog/config.yaml"
  local source
  source=$(grep 'template_source:' "$config" | sed 's/.*: "//' | tr -d '"')

  if [[ -z "$source" || ! -d "$source" ]]; then
    error "Template source not found."
    exit 1
  fi

  local agent=$(grep '^agent:' "$config" 2>/dev/null | head -1 | awk '{print $2}' | tr -d '"' || echo 'claude')
  local commands_dir=$(grep '^commands_dir:' "$config" 2>/dev/null | head -1 | sed 's/^commands_dir: "//' | tr -d '"' || get_commands_dir "$agent")

  log "Comparing project files with templates..."
  echo ""

  local has_diff=false

  # Compare commands
  info "Commands ($commands_dir):"
  for cmd in "$source/templates/commands"/*.md; do
    [[ -f "$cmd" ]] || continue
    local base_name=$(basename "$cmd" .md)
    local target_name=$(agent_command_filename "$agent" "$base_name")
    local target="$commands_dir/$target_name"

    if [[ ! -f "$target" ]]; then
      warn "  [missing] $target_name"
      has_diff=true
    elif diff -q "$cmd" "$target" > /dev/null 2>&1; then
      info "  [ok] $target_name"
    else
      warn "  [modified] $target_name"
      diff --color=always -u "$cmd" "$target" | head -30
      echo ""
      has_diff=true
    fi
  done

  # Compare skills
  echo ""
  info "Skills (.colog/skills):"
  for skill in "$source/templates/skills"/*.md; do
    [[ -f "$skill" ]] || continue
    local name=$(basename "$skill")
    local target=".colog/skills/$name"

    if [[ ! -f "$target" ]]; then
      warn "  [missing] $name"
      has_diff=true
    elif diff -q "$skill" "$target" > /dev/null 2>&1; then
      info "  [ok] $name"
    else
      warn "  [modified] $name"
      diff --color=always -u "$skill" "$target" | head -20
      echo ""
      has_diff=true
    fi
  done

  # Compare prompts
  echo ""
  info "Prompts (.colog/prompts):"
  for prompt in "$source/templates/prompts"/*.md; do
    [[ -f "$prompt" ]] || continue
    local name=$(basename "$prompt")
    local target=".colog/prompts/$name"

    if [[ ! -f "$target" ]]; then
      warn "  [missing] $name"
      has_diff=true
    elif diff -q "$prompt" "$target" > /dev/null 2>&1; then
      info "  [ok] $name"
    else
      warn "  [modified] $name"
      diff --color=always -u "$prompt" "$target" | head -20
      echo ""
      has_diff=true
    fi
  done

  echo ""
  if [[ "$has_diff" == false ]]; then
    log "Everything in sync."
  else
    log "Use 'colog update' to pull latest templates."
  fi
}

# ─── MAIN ──────────────────────────────────────────────────────────────────

AGENT="claude"
LANG_OPT="en"

while [[ $# -gt 0 ]]; do
  case "$1" in
    --agent)  AGENT="$2"; shift 2 ;;
    --lang)   LANG_OPT="$2"; shift 2 ;;
    --help)   usage; exit 0 ;;
    *)        break ;;
  esac
done

CMD="${1:-}"
shift || true

case "$CMD" in
  init)     cmd_init "$@" ;;
  setup)    cmd_setup "$@" ;;
  update)   cmd_update "$@" ;;
  sync)     cmd_sync "$@" ;;
  version)  echo "colog v${VERSION}" ;;
  "")       usage ;;
  *)        error "Unknown command: $CMD"; usage; exit 1 ;;
esac
